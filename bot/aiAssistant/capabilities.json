{
  "version": "1.0",
  "features": {
    "search_prices_for_dates": true,
    "search_by_destination": true,
    "search_by_exact_date": true,
    "shift_dates": false,
    "filter_by_duration": false,
    "filter_by_stops": false,
    "multi_city": false
  },
  "required_fields": ["origin"],
  "optional_fields": [
    "destination",
    "departure_at",
    "return_at",
    "one_way",
    "direct"
  ],
  "defaults": {
    "one_way": true,
    "direct": true
  },
  "supported_date_formats": ["YYYY-MM-DD", "YYYY-MM"]
}
